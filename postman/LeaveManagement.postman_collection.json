{
  "info": {
    "name": "Leave Management API - Real World Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5091"
    },
    {
      "key": "employeeToken",
      "value": ""
    },
    {
      "key": "managerToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "leaveRequestId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee@test.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('employeeToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@test.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('managerToken', pm.response.json().accessToken);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get My Leave Balance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/employees/101/leave-balance"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has balances', () => pm.expect(pm.response.json().balances).to.be.an('array').that.is.not.empty);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Leave Requests",
      "item": [
        {
          "name": "Submit Leave",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"Casual\",\n  \"startDate\": \"2026-08-03\",\n  \"endDate\": \"2026-08-05\",\n  \"reason\": \"Personal work\"\n}"
            },
            "url": "{{baseUrl}}/api/leave-requests"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json=pm.response.json();",
                  "pm.expect(json.status).to.eql('PENDING');",
                  "pm.collectionVariables.set('leaveRequestId', json.leaveRequestId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Manager Approves Leave",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{managerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Approved\",\n  \"comments\": \"Approved for testing\"\n}"
            },
            "url": "{{baseUrl}}/api/leave-requests/{{leaveRequestId}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().status).to.eql('APPROVED');"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel Leave",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/leave-requests/{{leaveRequestId}}/cancel"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().status).to.eql('CANCELLED');"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}